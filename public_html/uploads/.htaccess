Options -Indexes

# Never execute scripts or server-side includes inside the uploads directory.
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|pht|cgi|pl|py|sh|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>

# Disable PHP execution explicitly where the handler exists.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
